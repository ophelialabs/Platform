@rendermode InteractiveServer
@using cmd_cntr.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="navmenu">
    <input type="checkbox" title="Menu expand/collapse toggle" id="navmenu-toggle" class="navmenu-icon" />
    <label for="navmenu-toggle" class="navmenu-icon"><FluentIcon Value="@(new Icons.Regular.Size20.Navigation())" Color="Color.Fill" /></label>
    <nav class="sitenav" aria-labelledby="main-menu">
        <FluentNavMenu Id="main-menu" Collapsible="true" Width="250" Title="Navigation menu" @bind-Expanded="expanded" CustomToggle="true">
            <FluentNavLink Href="/" Match="NavLinkMatch.All" Icon="@(new Icons.Regular.Size20.Home())" IconColor="Color.Accent">Dashboard</FluentNavLink>
            
            @if (AuthService.HasRole("commander"))
            {
                <FluentNavGroup Title="Commander" Icon="@(new Icons.Regular.Size20.Shield())">
                    <FluentNavLink Href="operations" Icon="@(new Icons.Regular.Size20.Database())" IconColor="Color.Accent">Operations</FluentNavLink>
                    <FluentNavLink Href="personnel" Icon="@(new Icons.Regular.Size20.People())" IconColor="Color.Accent">Personnel</FluentNavLink>
                    <FluentNavLink Href="reports" Icon="@(new Icons.Regular.Size20.Document())" IconColor="Color.Accent">Reports</FluentNavLink>
                </FluentNavGroup>
            }
            
            @if (AuthService.HasRole("physician"))
            {
                <FluentNavGroup Title="Medical" Icon="@(new Icons.Regular.Size20.HeartCircle())">
                    <FluentNavLink Href="patients" Icon="@(new Icons.Regular.Size20.PeopleList())" IconColor="Color.Accent">Patients</FluentNavLink>
                    <FluentNavLink Href="vitals" Icon="@(new Icons.Regular.Size20.HeartPulse())" IconColor="Color.Accent">Vitals</FluentNavLink>
                </FluentNavGroup>
            }
            
            <FluentNavLink Href="counter" Icon="@(new Icons.Regular.Size20.NumberSymbolSquare())" IconColor="Color.Accent">Counter</FluentNavLink>
            <FluentNavLink Href="weather" Icon="@(new Icons.Regular.Size20.WeatherPartlyCloudyDay())" IconColor="Color.Accent">Weather</FluentNavLink>
        </FluentNavMenu>
    </nav>

    <div class="user-profile">
        <div class="user-info">
            <div class="user-role">@(AuthService.GetRole()?.ToUpper() ?? "USER")</div>
            <div class="user-name">@(AuthService.GetUserName() ?? "Guest")</div>
        </div>
        <button class="logout-btn" @onclick="Logout" title="Sign out">
            <FluentIcon Value="@(new Icons.Regular.Size20.SignOut())" />
        </button>
    </div>
</div>

@code {
    private bool expanded = true;

    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/login", replace: true);
    }
}

<style>
    .user-profile {
        border-top: 1px solid #e0e0e0;
        padding: 12px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fafafa;
    }

    .user-info {
        flex: 1;
    }

    .user-role {
        font-size: 11px;
        font-weight: 700;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 2px;
    }

    .user-name {
        font-size: 13px;
        font-weight: 500;
        color: #333;
    }

    .logout-btn {
        background: none;
        border: 1px solid #e0e0e0;
        border-radius: 4px;
        padding: 6px 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #666;
        transition: all 0.2s ease;
    }

    .logout-btn:hover {
        background: #fff;
        border-color: #999;
        color: #333;
    }
</style>
