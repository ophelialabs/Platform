@using Microsoft.FluentUI.AspNetCore.Components

<div class="dashboard-grid">
    <div class="dashboard-card">
        <div class="card-header commander">
            <FluentIcon Value="@(new Icons.Regular.Size24.Shield())" />
            <h3>Operational Status</h3>
        </div>
        <div class="card-content">
            <div class="status-item">
                <span class="status-label">Active Operations:</span>
                <span class="status-value">12</span>
            </div>
            <div class="status-item">
                <span class="status-label">Personnel Deployed:</span>
                <span class="status-value">347</span>
            </div>
            <div class="status-item">
                <span class="status-label">Equipment Status:</span>
                <span class="status-value operational">OPERATIONAL</span>
            </div>
        </div>
    </div>

    <div class="dashboard-card">
        <div class="card-header commander">
            <FluentIcon Value="@(new Icons.Regular.Size24.People())" />
            <h3>Personnel Overview</h3>
        </div>
        <div class="card-content">
            <div class="status-item">
                <span class="status-label">Total Personnel:</span>
                <span class="status-value">347</span>
            </div>
            <div class="status-item">
                <span class="status-label">Medical Staff:</span>
                <span class="status-value">28</span>
            </div>
            <div class="status-item">
                <span class="status-label">Support Staff:</span>
                <span class="status-value">89</span>
            </div>
        </div>
    </div>

    <div class="dashboard-card">
        <div class="card-header commander">
            <FluentIcon Value="@(new Icons.Regular.Size24.Document())" />
            <h3>Recent Reports</h3>
        </div>
        <div class="card-content">
            <ul class="report-list">
                <li>Daily Operations Report - 2 hours ago</li>
                <li>Personnel Status Update - 4 hours ago</li>
                <li>Equipment Maintenance Log - 6 hours ago</li>
            </ul>
        </div>
    </div>

    <div class="dashboard-card">
        <div class="card-header commander">
            <FluentIcon Value="@(new Icons.Regular.Size24.HeartPulse())" />
            <h3>Medical Summary</h3>
        </div>
        <div class="card-content">
            <div class="status-item">
                <span class="status-label">Personnel Under Care:</span>
                <span class="status-value">23</span>
            </div>
            <div class="status-item">
                <span class="status-label">Critical Cases:</span>
                <span class="status-value warning">3</span>
            </div>
            <div class="status-item">
                <span class="status-label">Medical Readiness:</span>
                <span class="status-value operational">95%</span>
            </div>
        </div>
    </div>
</div>

@code {
}

<style>
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .dashboard-card {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .dashboard-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    }

    .card-header {
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .card-header.commander {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .card-header h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
    }

    .card-content {
        padding: 16px;
    }

    .status-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .status-item:last-child {
        border-bottom: none;
    }

    .status-label {
        font-size: 13px;
        color: #666;
        font-weight: 500;
    }

    .status-value {
        font-size: 14px;
        font-weight: 600;
        color: #333;
    }

    .status-value.operational {
        color: #10b981;
    }

    .status-value.warning {
        color: #f59e0b;
    }

    .report-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .report-list li {
        padding: 8px 0;
        font-size: 13px;
        color: #555;
        border-bottom: 1px solid #f0f0f0;
    }

    .report-list li:last-child {
        border-bottom: none;
    }
</style>
