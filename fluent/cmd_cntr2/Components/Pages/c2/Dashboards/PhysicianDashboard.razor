@using Microsoft.FluentUI.AspNetCore.Components

<div class="dashboard-grid">
    <div class="dashboard-card">
        <div class="card-header physician">
            <FluentIcon Value="@(new Icons.Regular.Size24.PeopleList())" />
            <h3>Patients Under Care</h3>
        </div>
        <div class="card-content">
            <div class="status-item">
                <span class="status-label">Total Patients:</span>
                <span class="status-value">23</span>
            </div>
            <div class="status-item">
                <span class="status-label">Critical Status:</span>
                <span class="status-value warning">3</span>
            </div>
            <div class="status-item">
                <span class="status-label">Stable Status:</span>
                <span class="status-value operational">18</span>
            </div>
        </div>
    </div>

    <div class="dashboard-card">
        <div class="card-header physician">
            <FluentIcon Value="@(new Icons.Regular.Size24.HeartPulse())" />
            <h3>Vital Signs Monitor</h3>
        </div>
        <div class="card-content">
            <div class="status-item">
                <span class="status-label">Patients Being Monitored:</span>
                <span class="status-value">23</span>
            </div>
            <div class="status-item">
                <span class="status-label">Last Update:</span>
                <span class="status-value">2 minutes ago</span>
            </div>
            <div class="status-item">
                <span class="status-label">Alert Status:</span>
                <span class="status-value operational">NORMAL</span>
            </div>
        </div>
    </div>

    <div class="dashboard-card">
        <div class="card-header physician">
            <FluentIcon Value="@(new Icons.Regular.Size24.PeopleList())" />
            <h3>Patient Assignments</h3>
        </div>
        <div class="card-content">
            <ul class="patient-list">
                <li><span class="patient-id">PT-001</span> <span class="patient-status">Stable</span></li>
                <li><span class="patient-id">PT-002</span> <span class="patient-status">Stable</span></li>
                <li><span class="patient-id">PT-003</span> <span class="patient-status critical">Critical</span></li>
            </ul>
        </div>
    </div>

    <div class="dashboard-card">
        <div class="card-header physician">
            <FluentIcon Value="@(new Icons.Regular.Size24.Document())" />
            <h3>Recent Medical Notes</h3>
        </div>
        <div class="card-content">
            <ul class="note-list">
                <li>Patient PT-001: Vitals stable - 15 mins ago</li>
                <li>Patient PT-002: Medication administered - 1 hour ago</li>
                <li>Patient PT-003: Under observation - 3 hours ago</li>
            </ul>
        </div>
    </div>
</div>

@code {
}

<style>
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .dashboard-card {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .dashboard-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    }

    .card-header {
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: white;
    }

    .card-header.physician {
        background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
    }

    .card-header h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
    }

    .card-content {
        padding: 16px;
    }

    .status-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .status-item:last-child {
        border-bottom: none;
    }

    .status-label {
        font-size: 13px;
        color: #666;
        font-weight: 500;
    }

    .status-value {
        font-size: 14px;
        font-weight: 600;
        color: #333;
    }

    .status-value.operational {
        color: #10b981;
    }

    .status-value.warning {
        color: #f59e0b;
    }

    .patient-list,
    .note-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .patient-list li,
    .note-list li {
        padding: 8px 0;
        font-size: 13px;
        color: #555;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        justify-content: space-between;
    }

    .patient-list li:last-child,
    .note-list li:last-child {
        border-bottom: none;
    }

    .patient-id {
        font-weight: 600;
        color: #333;
    }

    .patient-status {
        font-size: 12px;
        padding: 2px 8px;
        border-radius: 4px;
        background: #e8f5e9;
        color: #10b981;
    }

    .patient-status.critical {
        background: #ffe8e8;
        color: #ef4444;
    }
</style>
