@page "/q-net"
@using System.Collections.Generic

<PageTitle>Quantum Network Visualization</PageTitle>

<div class="quantum-network-container">
    <canvas @ref="canvasElement" class="quantum-canvas"></canvas>
    <div class="controls">
        <button @onclick="ToggleLabels" class="btn">@(showLabels ? "Hide" : "Show") Labels</button>
        <button @onclick="ToggleRotation" class="btn">@(isRotating ? "Stop" : "Start") Rotation</button>
    </div>
    <div class="node-info">
        @if (focusedNode != null)
        {
            <div class="info-panel">
                <h3>@focusedNode.Name</h3>
                <p><strong>Status:</strong> @focusedNode.Status</p>
                <p><strong>Capacity:</strong> @focusedNode.Capacity Tbps</p>
                <p><strong>Region:</strong> @focusedNode.Region</p>
                <p><strong>Location:</strong> @focusedNode.Latitude.ToString("F4"), @focusedNode.Longitude.ToString("F4")</p>
            </div>
        }
        else
        {
            <p class="text-muted">Click on a network node to view details</p>
        }
    </div>
</div>

