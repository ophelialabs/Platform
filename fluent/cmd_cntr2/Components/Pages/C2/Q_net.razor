    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            StateHasChanged();
        }
    }

    private void ToggleLabels()
    {
        showLabels = !showLabels;
    }

    private void ToggleRotation()
    {
        isRotating = !isRotating;
    }

    private void SelectNode(QuantumNode node)
    {
        focusedNode = focusedNode?.Id == node.Id ? null : node;
    }
}

<style>
    .quantum-network-container {
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        gap: 20px;
        padding: 20px;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }

    .quantum-canvas {
        flex: 1;
        min-height: 600px;
        border-radius: 12px;
        background: #0f172a;
        border: 2px solid #334155;
        cursor: crosshair;
    }

    .controls {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn {
        padding: 12px 24px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        font-size: 14px;
    }

    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .btn:active {
        transform: translateY(0);
    }

    .node-info {
        min-height: 120px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #334155;
    }

    .info-panel {
        color: #e2e8f0;
    }

    .info-panel h3 {
        margin: 0 0 12px 0;
        color: #60a5fa;
        font-size: 18px;
        font-weight: 600;
    }

    .info-panel p {
        margin: 8px 0;
        font-size: 14px;
        line-height: 1.6;
    }

    .text-muted {
        color: #94a3b8;
        margin: 0;
        font-style: italic;
    }

    @@media (max-width: 768px) {
        .quantum-network-container {
            padding: 12px;
            gap: 15px;
        }

        .quantum-canvas {
            min-height: 400px;
        }

        .controls {
            gap: 8px;
        }

        .btn {
            padding: 10px 16px;
            font-size: 12px;
        }

        .node-info {
            min-height: 100px;
            padding: 15px;
        }

        .info-panel h3 {
            font-size: 16px;
        }

        .info-panel p {
            font-size: 12px;
        }
    }
</style>
