@page "/chemistry"

<PageTitle>Chemistry - Learning Platform</PageTitle>

<LP_app.Components.Pages.Learning.DTOs.CourseHeader 
    CourseName="Chemistry"
    Description="Master fundamental and advanced chemistry concepts including organic, inorganic, and analytical chemistry."
    Duration="6 months"
    LessonCount="32"
    HasCertificate="true" />

<div class="learning-cta">
    <a href="/chemistry/learning" class="btn btn-primary btn-lg">
        <i class="bi bi-play-circle-fill"></i> Start Interactive Learning
    </a>
</div>

<div class="container">
    <section class="course-overview">
        <h2>Course Modules</h2>
        <div class="overview-grid">
            <div class="overview-card">
                <div class="card-number">1</div>
                <h3>General Chemistry</h3>
                <p>Atoms, molecules, reactions, and fundamental chemical principles.</p>
                <div class="card-meta">8 lessons • 6 hours</div>
                <a href="/chemistry/learning" class="btn btn-sm btn-primary">Start Module</a>
            </div>
            <div class="overview-card">
                <div class="card-number">2</div>
                <h3>Organic Chemistry</h3>
                <p>Carbon compounds, reaction mechanisms, and synthesis strategies.</p>
                <div class="card-meta">9 lessons • 7 hours</div>
                <a href="/chemistry/learning" class="btn btn-sm btn-primary">Start Module</a>
            </div>
            <div class="overview-card">
                <div class="card-number">3</div>
                <h3>Analytical Chemistry</h3>
                <p>Analytical techniques, laboratory procedures, and data analysis.</p>
                <div class="card-meta">6 lessons • 4.5 hours</div>
                <a href="/chemistry/learning" class="btn btn-sm btn-primary">Start Module</a>
            </div>
        </div>
    </section>

<section class="tools-section">
    <h2>Tools You'll Master</h2>
    <div class="tools-grid">
        @foreach (var tool in Tools)
        {
            <a href="@tool.Value" target="_blank" rel="noopener noreferrer" class="tool-badge">
                @tool.Key
            </a>
        }
    </div>
</section>


    <section class="requirements-section">
        <h2>What You'll Learn</h2>
        <div class="requirements-grid">
            <div class="requirement">
                <h4>✓ General Chemistry</h4>
                <p>Atomic structure, chemical bonding, and stoichiometry.</p>
            </div>
            <div class="requirement">
                <h4>✓ Organic Chemistry</h4>
                <p>Nomenclature, reaction mechanisms, and synthesis.</p>
            </div>
            <div class="requirement">
                <h4>✓ Analytical Methods</h4>
                <p>Spectroscopy, chromatography, and instrumental analysis.</p>
            </div>
            <div class="requirement">
                <h4>✓ Laboratory Techniques</h4>
                <p>Titrations, crystallization, and experimental procedures.</p>
            </div>
            <div class="requirement">
                <h4>✓ Physical Chemistry</h4>
                <p>Thermodynamics, kinetics, and equilibrium.</p>
            </div>
            <div class="requirement">
                <h4>✓ Lab Project</h4>
                <p>Design and execute a complete chemistry experiment.</p>
            </div>
        </div>
    </section>

    <section class="research-section">
        <h2>Research & Resources</h2>
        <div class="resources-grid">
            <div class="resource-item">
                <h3>Key Organizations</h3>
                <ul>
                    <li><a href="https://www.acs.org/" target="_blank">American Chemical Society (ACS)</a></li>
                    <li>Professional organization for chemists with journals, conferences, and resources</li>
                    <li>Access to cutting-edge research and career opportunities</li>
                </ul>
            </div>
            <div class="resource-item">
                <h3>Research Topics</h3>
                <ul>
                    <li>Organic synthesis and asymmetric catalysis</li>
                    <li>Analytical spectroscopy and instrumental methods</li>
                    <li>Computational chemistry and molecular modeling</li>
                    <li>Green chemistry and sustainable processes</li>
                </ul>
            </div>
        </div>
    </section>

    <section class="applications-section">
        <h2>Real-World Applications</h2>
        <div class="applications-grid">
            <div class="application-card">
                <h3>Pharmaceutical Development</h3>
                <p>Design and synthesize new drug molecules using organic chemistry principles and high-throughput screening methods.</p>
            </div>
            <div class="application-card">
                <h3>Materials Science</h3>
                <p>Create advanced materials with novel properties through chemical modification and characterization techniques.</p>
            </div>
            <div class="application-card">
                <h3>Environmental Analysis</h3>
                <p>Monitor and analyze environmental samples using analytical chemistry and instrumental techniques.</p>
            </div>
            <div class="application-card">
                <h3>Industrial Chemistry</h3>
                <p>Optimize chemical processes for production scale and cost-effectiveness in manufacturing.</p>
            </div>
            <div class="application-card">
                <h3>Forensic Science</h3>
                <p>Apply analytical chemistry to identify and analyze evidence in criminal investigations.</p>
            </div>
            <div class="application-card">
                <h3>Quality Control</h3>
                <p>Ensure product quality through chemical testing and standardized analytical procedures.</p>
            </div>
        </div>
    </section>
</div>

@code {
    private List<LP_app.Components.Pages.Learning.DTOs.LessonsList.LessonItem> Lessons { get; set; } = new();
    private List<LP_app.Components.Pages.Learning.DTOs.QuizzesList.QuizItem> Quizzes { get; set; } = new();

    private Dictionary<string, string> Tools = new()
    {
        { "ChemDraw", "https://www.revvitysignals.com" },
        { "GAMESS", "https://www.msg.chem.iastate.edu" },
        { "SMILES", "https://opensmiles.org" },
        { "PyMOL", "https://www.pymol.org" },
        { "Avogadro", "https://avogadro.cc" },
        { "Spartan", "https://www.wavefun.com" }
    };


    protected override void OnInitialized() {
        Lessons = new()
        {
            new() { 
                Title = "Chemistry Fundamentals", 
                Description = "Overview", 
                Duration = "2 hours", 
                Link = "/lesson/chem-intro", 
                Topics = new() { "Basics" } 
            }
        };

        Quizzes = new()
        {
            new() { 
                Title = "Chemistry Quiz", 
                Description = "Test", 
                Questions = 15, 
                TimeLimit = 25, 
                Link = "/quiz/chem-101" 
            }
        };
    }
}

<style>
    .learning-cta {
        text-align: center;
        padding: 30px 20px;
        background: linear-gradient(135deg, #e3f2fd 0%, #f0f7ff 100%);
        border-radius: 8px;
        margin: -20px 0 40px 0;
    }

    .learning-cta .btn {
        box-shadow: 0 4px 12px rgba(27, 110, 194, 0.3);
    }

    .learning-cta .btn:hover {
        box-shadow: 0 6px 16px rgba(27, 110, 194, 0.4);
        transform: translateY(-2px);
    }

    .course-overview { 
        margin: 40px 0; 
    }

    .course-overview h2 {
        font-size: 1.6rem;
        color: #333;
        margin-bottom: 30px;
        font-weight: 700;
    }

    .overview-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); 
        gap: 25px; 
    }

    .overview-card { 
        background: white; 
        padding: 25px; 
        border-radius: 8px; 
        border-left: 4px solid #1b6ec2; 
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        position: relative;
        display: flex;
        flex-direction: column;
    }

    .overview-card:hover { 
        box-shadow: 0 6px 16px rgba(0,0,0,0.12); 
        transform: translateY(-4px); 
    }

    .card-number {
        position: absolute;
        top: -15px;
        left: 25px;
        width: 40px;
        height: 40px;
        background: #1b6ec2;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.2rem;
    }

    .overview-card h3 {
        color: #333;
        font-weight: 700;
        margin: 15px 0 12px 0;
    }

    .overview-card p {
        color: #666;
        margin-bottom: 15px;
        line-height: 1.6;
        flex: 1;
    }

    .card-meta {
        font-size: 0.85rem;
        color: #999;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 1px solid #eee;
    }

    .tools-section {
        margin: 40px 0;
        padding: 30px;
        background: #f8f9fa;
        border-radius: 8px;
    }

    .tools-section h2 {
        font-size: 1.8rem;
        margin-bottom: 25px;
        color: #333;
        font-weight: 700;
    }

    .tools-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 15px;
    }

    .tool-badge {
        background: white;
        padding: 12px 15px;
        border-radius: 6px;
        text-align: center;
        font-weight: 600;
        color: #1b6ec2;
        border: 1px solid #1b6ec2;
        transition: all 0.3s ease;
    }

    .tool-badge:hover {
        background: #1b6ec2;
        color: white;
    }

    .requirements-section {
        margin: 40px 0;
    }

    .requirements-section h2 {
        font-size: 1.8rem;
        margin-bottom: 25px;
        color: #333;
        font-weight: 700;
    }

    .requirements-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
    }

    .requirement {
        background: white;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
    }

    .requirement:hover {
        box-shadow: 0 6px 16px rgba(0,0,0,0.12);
    }

    .requirement h4 {
        color: #1b6ec2;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .requirement p {
        color: #666;
        margin: 0;
        line-height: 1.6;
        font-size: 0.95rem;
    }

    .research-section {
        margin: 40px 0;
    }

    .research-section h2 {
        font-size: 1.8rem;
        margin-bottom: 25px;
        color: #333;
        font-weight: 700;
    }

    .resources-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
    }

    .resource-item {
        background: white;
        padding: 25px;
        border-radius: 8px;
        border: 1px solid #ddd;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
    }

    .resource-item:hover {
        border-color: #1b6ec2;
        box-shadow: 0 6px 16px rgba(27, 110, 194, 0.15);
    }

    .resource-item h3 {
        color: #1b6ec2;
        font-weight: 700;
        margin-top: 0;
        margin-bottom: 15px;
    }

    .resource-item ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .resource-item li {
        color: #666;
        margin: 8px 0;
        line-height: 1.6;
    }

    .resource-item a {
        color: #1b6ec2;
        text-decoration: none;
        font-weight: 500;
    }

    .resource-item a:hover {
        text-decoration: underline;
    }

    .applications-section {
        margin: 40px 0;
    }

    .applications-section h2 {
        font-size: 1.8rem;
        margin-bottom: 25px;
        color: #333;
        font-weight: 700;
    }

    .applications-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
    }

    .application-card {
        background: #f0f5ff;
        padding: 20px;
        border-radius: 8px;
        border-left: 4px solid #1b6ec2;
        transition: all 0.3s ease;
    }

    .application-card:hover {
        background: white;
        box-shadow: 0 6px 16px rgba(27, 110, 194, 0.15);
    }

    .application-card h3 {
        color: #1b6ec2;
        font-weight: 700;
        margin: 0 0 10px 0;
        font-size: 1.05rem;
    }

    .application-card p {
        color: #666;
        margin: 0;
        line-height: 1.6;
        font-size: 0.95rem;
    }
</style>
