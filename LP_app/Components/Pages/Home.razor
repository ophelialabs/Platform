@page "/"

<PageTitle>Learning Platform - Professional Courses</PageTitle>

<div class="hero-section">
    <div class="hero-content">
        <h1>Welcome to the Platform</h1>
        <p class="hero-subtitle"></p>
        <div class="hero-buttons">
            <a href="" class="btn btn-primary btn-lg">#</a>
            <a href="" class="btn btn-outline-primary btn-lg">#</a>
        </div>
    </div>
</div>

<section class="featured-courses">
    <div class="container">
        <h2>References</h2>
        <div class="courses-grid">
            <div class="course-card">
                <div class="course-icon"></div>
                <h3>Nuget</h3>
                <p>Learn to use Nuget Packages and Libraries</p>
                <a href="https://nuget.org/" class="btn btn-sm btn-primary">Explore</a>
            </div>
            <div class="course-card">
                <div class="course-icon"></div>
                <h3>.NET</h3>
                <p>Learn the fundamentals of .NET development and build modern applications.</p>
                <a href="https://learn.microsoft.com/en-us/dotnet/?WT.mc_id=dotnet-35129-website" class="btn btn-sm btn-primary">Explore</a>
            </div>
            <div class="course-card">
                <div class="course-icon"></div>
                <h3>Aspire</h3>
                <p>dotnet workload install aspire</p>
                <p>dotnet new install Aspire.ProjectTemplates</p>
                <p>dotnet new aspire-starter -o MyFirstAspireApp</p>
                <a href="https://aspire.dev/integrations/cloud/azure/overview/" class="btn btn-sm btn-primary">Explore</a>
            </div>
            <div class="course-card">
                <div class="course-icon"></div>
                <h3>Microsoft Agent Framework</h3>
                <p>dotnet new install Microsoft.AgentFramework.Templates</p>
                <p>dotnet new agentframework-csharp -o MyAgentFrameworkCSharpApp</p>
                <a href="https://docs.copilotkit.ai/microsoft-agent-framework" class="btn btn-sm btn-primary">Explore</a>

            <!-- Pre-built UI Component Libraries for Blazor -->
            <div class="course-card">
                <div class="course-icon"></div>
                <h3>UI Component Libraries for Blazor</h3>
                <p>Explore popular UI component libraries to accelerate your Blazor development</p>
                <div class="dropdown">
                    <button class="btn btn-sm btn-primary dropdown-toggle" type="button" id="designToolsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        Explore Tools
                    </button>
                    <ul class="dropdown-menu" aria-labelledby="Dropdown">
                        <li><a class="dropdown-item" href="https://www.fluentui-blazor.net/" target="_blank">Fluent UI</a></li>
                        <li><a class="dropdown-item" href="https://www.infragistics.com/products/ignite-ui-blazor/blazor/components/general-getting-started" target="_blank">Ignite UI</a></li>
                        <li><a class="dropdown-item" href="https://www.radzen.com/blazor-studio" target="_blank">Radzen</a></li>
                        <li><a class="dropdown-item" href="https://demos.telerik.com/blazor-coffee/" target="_blank">Telerik UI</a></li>
                        <li><a class="dropdown-item" href="https://blazorise.com/" target="_blank">Blazorise</a></li>
                        <li><a class="dropdown-item" href="https://mudblazor.com/" target="_blank">MudBlazor</a></li>
                    </ul>
                </div>
            </div>

<!-- 
dotnet new install Microsoft.FluentUI.AspNetCore.Templates
dotnet new fluentui-blazor -o MyFluentUIBlazorApp

dotnet new install Infragistics.Blazor.Templates
dotnet new ig-blazor -o MyIgniteUIBlazorApp

dotnet new install Radzen.Blazor.Templates
dotnet new radzen-blazor -o MyRadzenBlazorApp

dotnet new install Telerik.Blazor.Templates
dotnet new telerik-blazor -o MyTelerikBlazorApp
-->

            <!-- Design Tools for UI/UX -->
            <div class="course-card">
                <div class="course-icon"></div>
                <h3>Design Tools for UI/UX</h3>
                <p>Professional design tools for creating modern user interfaces</p>
                <div class="dropdown">
                    <button class="btn btn-sm btn-primary dropdown-toggle" type="button" id="designToolsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        Explore Tools
                    </button>
                    <ul class="dropdown-menu" aria-labelledby="Dropdown">
                        <li><a class="dropdown-item" href="https://ophelialabs2.github.io/JB_template/1-3/#architecture" target="_blank">Figma</a></li>
                        <li><a class="dropdown-item" href="https://www.adobe.com/products/xd.html" target="_blank">Adobe XD</a></li>
                        <li><a class="dropdown-item" href="https://www.sketch.com/" target="_blank">Sketch</a></li>
                        <li><a class="dropdown-item" href="https://www.invisionapp.com/" target="_blank">InVision</a></li>
                        <li><a class="dropdown-item" href="https://www.axure.com/" target="_blank">Axure RP</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="platform-features">
    <div class="container">
        <h2>Why Choose Our Platform?</h2>
        <div class="features-grid">
            <div class="feature">
                <span class="feature-icon">✓</span>
                <h4></h4>
                <p></p>
            </div>
            <div class="feature">
                <span class="feature-icon">✓</span>
                <h4></h4>
                <p></p>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <h2>Ready to Start Learning?</h2>
        <p>Join thousands of students advancing their careers</p>
        <a href="/register" class="btn btn-primary btn-lg">Sign Up Today</a>
    </div>
</section>
